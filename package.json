{
  "name": "homer-agent",
  "version": "1.0.0",
  "description": "Homer Simpson AI Agent — Talk to Homer in your terminal or browser. Powered by xAI Grok.",
  "type": "module",
  "bin": {
    "homer-agent": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:web": "node dist/main.js --serve",
    "dev": "npx tsx src/main.ts",
    "dev:web": "npx tsx src/main.ts --serve",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "homer",
    "simpson",
    "ai",
    "agent",
    "chatbot",
    "cli",
    "grok",
    "xai"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "public",
    "data",
    ".env.example"
  ],
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "openai": "^6.25.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
